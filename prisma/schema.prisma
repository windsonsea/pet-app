generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Pet {
  id        String   @id @default(cuid())
  name      String
  species   String   // 狗、猫、兔子等
  breed     String?
  birthDate String?  // ISO date
  gender    String?
  weight    Float?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  healthRecords HealthRecord[]
  dailyNotes    DailyNote[]
}

model HealthRecord {
  id        String   @id @default(cuid())
  petId     String
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  type      String   // vaccination, checkup, medication, weight, other
  title     String
  note      String?
  value     Float?   // 体重值等
  unit      String?  // kg, g 等
  date      String   // ISO date
  createdAt DateTime @default(now())
}

model DailyNote {
  id        String   @id @default(cuid())
  petId     String
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  content   String
  mood      String?  // happy, neutral, sad
  imageUrl  String?
  createdAt DateTime @default(now())
}

model Checkin {
  id        String   @id @default(cuid())
  type      String   // health, habit, custom
  date      String   // ISO date (YYYY-MM-DD)
  completed Boolean  @default(false)
  note      String?
  createdAt DateTime @default(now())
}

model ForumPost {
  id        String   @id @default(cuid())
  author    String
  text      String
  time      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
